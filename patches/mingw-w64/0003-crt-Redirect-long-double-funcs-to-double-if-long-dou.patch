 mingw-w64-crt/math/x86/atan2l.c     | 5 +++++
 mingw-w64-crt/math/x86/atanl.c      | 5 +++++
 mingw-w64-crt/math/x86/ceill.S      | 4 ++++
 mingw-w64-crt/math/x86/copysignl.S  | 4 ++++
