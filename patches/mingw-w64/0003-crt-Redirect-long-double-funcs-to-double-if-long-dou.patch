 mingw-w64-crt/math/x86/log10l.S     | 4 ++++
 mingw-w64-crt/math/x86/log1pl.S     | 4 ++++
 mingw-w64-crt/math/x86/log2l.S      | 4 ++++
 mingw-w64-crt/math/x86/logl.c       | 9 +++++++++
 mingw-w64-crt/math/x86/nearbyintl.S | 4 ++++
 mingw-w64-crt/math/x86/powl.c       | 8 ++++++++
 mingw-w64-crt/math/x86/remainderl.S | 4 ++++
