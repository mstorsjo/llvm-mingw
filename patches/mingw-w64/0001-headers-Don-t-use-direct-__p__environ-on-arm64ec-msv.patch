From 6b4cf33549943e119c0a6229dd9fe09a8d533c9b Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Martin=20Storsj=C3=B6?= <martin@martin.st>
Date: Mon, 1 Sep 2025 13:49:33 +0300
Subject: [PATCH 1/3] headers: Don't use direct __p__environ() on arm64ec
 msvcrt.dll

The function __p__environ() only exists on x86 on msvcrt.dll;
prefer the _get_environ approach on arm64ec.

This provides a read-only rvalue from _environ, like on aarch64
on msvcrt.dll. It should be possible to provide the writable
version of it like on x86_64 as well, by compiling the
misc/__p__environ.c helper for arm64ec as well, but as msvcrt.dll
configurations on arm64ec is an unimportant configuration overall,
just pick the simplest solution.
---
 mingw-w64-headers/crt/stdlib.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mingw-w64-headers/crt/stdlib.h b/mingw-w64-headers/crt/stdlib.h
index 482971357..2a4359352 100644
--- a/mingw-w64-headers/crt/stdlib.h
+++ b/mingw-w64-headers/crt/stdlib.h
@@ -192,7 +192,7 @@ _CRTIMP int __cdecl ___mb_cur_max_func(void);
 #endif
 
 #ifndef _POSIX_
-#if (defined(_ARM_) || defined(__arm__) || defined(_ARM64_) || defined(__aarch64__)) && !defined(_UCRT)
+#if (defined(_ARM_) || defined(__arm__) || defined(_ARM64_) || defined(__aarch64__) || defined(_ARM64EC_) || defined(__arm64ec__)) && !defined(_UCRT)
   /* The plain msvcrt.dll for arm/aarch64 lacks
    * _environ/_wenviron, but has these functions instead. */
   _CRTIMP void __cdecl _get_environ(char ***);
-- 
